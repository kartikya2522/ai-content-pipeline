        "message": "=<div style=\"font-family: Arial, sans-serif; max-width: 600px; margin: auto; background-color: #f4f6f9; padding: 20px; border-radius: 12px;\">\n\n  <!-- HEADER -->\n  <div style=\"background: linear-gradient(135deg, #0077B5, #00A0DC); padding: 30px 20px; border-radius: 10px 10px 0 0; text-align: center;\">\n    <h1 style=\"color: white; margin: 0; font-size: 24px; letter-spacing: 1px;\">🤖 AI Content Pipeline</h1>\n    <p style=\"color: #cce8ff; margin: 8px 0 0; font-size: 13px;\">Automated by n8n + Gemini AI — Pixnom Technologies</p>\n  </div>\n\n  <!-- BODY -->\n  <div style=\"background: white; padding: 28px; border-radius: 0 0 10px 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);\">\n\n    <!-- STATUS BADGE -->\n    <div style=\"display: inline-block; background-color: #e8f5e9; color: #2e7d32; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: bold; margin-bottom: 20px;\">\n      ✅ Ready for Review & Publishing\n    </div>\n\n    <!-- SOURCE -->\n    <div style=\"margin-bottom: 20px;\">\n      <h3 style=\"color: #0077B5; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 6px;\">📰 Source Article</h3>\n      <p style=\"margin: 0; color: #444; font-size: 14px; line-height: 1.5;\">{{$('Information').item.json.Titulo_original}}</p>\n    </div>\n\n    <hr style=\"border: none; border-top: 1px solid #eee; margin: 20px 0;\">\n\n    <!-- LINKEDIN POST -->\n    <div style=\"margin-bottom: 20px;\">\n      <h3 style=\"color: #0077B5; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 10px;\">✍️ AI Generated LinkedIn Post</h3>\n      <div style=\"background: #f0f7ff; border-left: 4px solid #0077B5; padding: 18px; border-radius: 6px; color: #333; font-size: 14px; line-height: 1.8;\">\n        {{$node[\"AI Agent2\"].json.output}}\n      </div>\n    </div>\n\n    <hr style=\"border: none; border-top: 1px solid #eee; margin: 20px 0;\">\n\n    <!-- HASHTAGS -->\n    <div style=\"margin-bottom: